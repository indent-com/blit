---
type Feature = {
  title: string;
  desc: string;
  bullets: string[];
  icon: "stream" | "share" | "robot" | "cube" | "embed" | "layers";
  badge?: string;
};

const features: Feature[] = [
  {
    title: "Live state, not pixels",
    desc:
      "blit parses the full terminal grid and ships only the cells that changed — LZ4-compressed binary diffs, scrolling encoded as copy-rect ops, WebGL-rendered. Select text. Resize freely. Type into it.",
    bullets: ["Per-client backpressure", "RTT-bound keystrokes", "WebGL renderer"],
    icon: "stream",
  },
  {
    title: "Share with one command",
    desc:
      "blit share prints a URL anyone can open. WebRTC punches through NATs — no SSH keys, no port forwarding. Named SSH remotes auto-install on first connect.",
    bullets: ["Read-only share links", "WebRTC NAT traversal", "ssh-agent + ~/.ssh/config"],
    icon: "share",
  },
  {
    title: "Terminals as an API",
    desc:
      "Non-interactive subcommands for scripts and LLMs: start, send, show, wait --pattern. We publish a computer-agent skill — drop it straight into any AI agent.",
    bullets: ["JSON-friendly output", "Pattern-matched waits", "Agent skill on a URL"],
    icon: "robot",
  },
  {
    title: "GUI apps & audio",
    desc:
      "Every blit terminal includes an experimental headless Wayland compositor. Launch GUI apps and stream them as H.264 / AV1. Audio forwarded via PipeWire as Opus.",
    bullets: ["Vulkan / VA-API / NVENC", "Surface click + screenshot", "No display required"],
    icon: "cube",
    badge: "Experimental · Linux",
  },
  {
    title: "Embeddable",
    desc:
      "@blit-sh/react and @blit-sh/solid expose framework bindings. WebGPU rendered (WebGL2 fallback), fully interactive, zero DOM manipulation.",
    bullets: ["React + Solid components", "Workspace + connections API", "Tree-shake friendly"],
    icon: "embed",
  },
  {
    title: "Stateful core, restartable shell",
    desc:
      "PTYs and parsed state live in a single server process. Gateways and proxies above the Unix socket are stateless — restart them, your terminals don't blink.",
    bullets: ["proxy-daemon connection pool", "blit gateway as a service", "QUIC + WebTransport"],
    icon: "layers",
  },
];
---

<section id="features" class="border-b border-[var(--border)] bg-[var(--bg)]">
  <div class="mx-auto max-w-6xl px-6 py-20 max-sm:px-4 max-sm:py-14">
    <div class="max-w-2xl">
      <div
        class="font-mono text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--accent)]"
      >
        What's inside
      </div>
      <h2
        class="mt-3 font-sans text-[clamp(1.7rem,3.4vw,2.4rem)] font-bold leading-tight tracking-[-0.02em] text-[var(--bright)]"
      >
        A terminal stack that takes <span class="grad-text">latency</span> seriously.
      </h2>
      <p class="mt-3 text-[15px] text-[var(--dim)]">
        Every line of output is parsed, diffed, compressed, and paced.
        Every keystroke goes straight to the PTY. The server is the
        stateful half — everything above it is restartable.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map(({ title, desc, bullets, icon, badge }) => (
          <article class="card-hover group flex flex-col rounded-xl border border-[var(--border)] bg-[var(--bg-elevated)] p-5">
            <div class="flex items-center justify-between">
              <span class="grid h-9 w-9 place-items-center rounded-lg border border-[var(--border)] bg-[var(--surface)] text-[var(--accent)] transition-colors group-hover:border-[var(--accent)] group-hover:bg-[var(--accent-soft)]">
                {icon === "stream" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                    <path d="M2 4h12M2 8h8M2 12h12" />
                    <circle cx="13.5" cy="8" r="1.2" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {icon === "share" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="4" cy="8" r="2" />
                    <circle cx="12" cy="3.5" r="2" />
                    <circle cx="12" cy="12.5" r="2" />
                    <path d="M5.7 7l4.6-2.7M5.7 9l4.6 2.7" />
                  </svg>
                )}
                {icon === "robot" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2.5" y="5" width="11" height="8" rx="2" />
                    <path d="M8 2.5V5" />
                    <circle cx="6" cy="9" r="0.8" fill="currentColor" stroke="none" />
                    <circle cx="10" cy="9" r="0.8" fill="currentColor" stroke="none" />
                    <path d="M0.5 9.5v-1M15.5 9.5v-1" />
                  </svg>
                )}
                {icon === "cube" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
                    <path d="M8 1.5l5.5 3v6L8 13.5 2.5 10.5v-6L8 1.5Z" />
                    <path d="M2.5 4.5L8 7.5l5.5-3M8 7.5v6" />
                  </svg>
                )}
                {icon === "embed" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 4l-3 4 3 4M11 4l3 4-3 4M9.5 3.5l-3 9" />
                  </svg>
                )}
                {icon === "layers" && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
                    <path d="M8 1.5l6 3-6 3-6-3 6-3Z" />
                    <path d="M2 8l6 3 6-3M2 11.5l6 3 6-3" />
                  </svg>
                )}
              </span>
              {badge && (
                <span class="rounded-full border border-[var(--accent)]/40 bg-[var(--accent-soft)] px-2 py-0.5 font-mono text-[9px] font-bold uppercase tracking-wider text-[var(--accent)]">
                  {badge}
                </span>
              )}
            </div>
            <h3 class="mt-4 font-mono text-[15px] font-bold tracking-tight text-[var(--bright)]">
              {title}
            </h3>
            <p class="mt-2 text-[13.5px] leading-relaxed text-[var(--dim)]">
              {desc}
            </p>
            <ul class="mt-4 flex flex-col gap-1.5 border-t border-dashed border-[var(--border)] pt-3 text-[12px] text-[var(--dim)]">
              {bullets.map((b) => (
                <li class="flex items-start gap-2">
                  <span class="mt-[6px] h-1 w-1 shrink-0 rounded-full bg-[var(--accent)]" />
                  <span class="font-mono">{b}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
