---
type Cell = "y" | "n" | "p" | string;
type Row = {
  feature: string;
  blit: Cell;
  ttyd: Cell;
  gotty: Cell;
  eternal: Cell;
  mosh: Cell;
  xterm: Cell;
};

const rows: Row[] = [
  { feature: "Architecture", blit: "Single binary", ttyd: "Single binary", gotty: "Single binary", eternal: "Client + daemon", mosh: "Client + server", xterm: "Library" },
  { feature: "Multiple PTYs", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "p" },
  { feature: "Browser access", blit: "y", ttyd: "y", gotty: "y", eternal: "n", mosh: "n", xterm: "y" },
  { feature: "Delta updates", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "y", xterm: "n" },
  { feature: "LZ4 compression", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "n" },
  { feature: "Per-client backpressure", blit: "y", ttyd: "n", gotty: "n", eternal: "p", mosh: "n", xterm: "n" },
  { feature: "GPU rendering (WebGPU/WebGL2)", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "p" },
  { feature: "Embeddable (React/Solid)", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "y" },
  { feature: "Wayland compositor", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "n" },
  { feature: "GUI app streaming", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "n" },
  { feature: "Agent / CLI subcommands", blit: "y", ttyd: "n", gotty: "n", eternal: "n", mosh: "n", xterm: "n" },
  { feature: "SSH tunneling built-in", blit: "y", ttyd: "n", gotty: "n", eternal: "y", mosh: "y", xterm: "n" },
];

const cols: Array<{ key: keyof Row; label: string; sub?: string; highlight?: boolean }> = [
  { key: "blit", label: "blit", highlight: true },
  { key: "ttyd", label: "ttyd" },
  { key: "gotty", label: "gotty" },
  { key: "eternal", label: "Eternal", sub: "Terminal" },
  { key: "mosh", label: "Mosh" },
  { key: "xterm", label: "xterm.js", sub: "+ node-pty" },
];

function cellText(v: Cell): string {
  if (v === "y") return "✓";
  if (v === "n") return "—";
  if (v === "p") return "~";
  return v;
}
function cellClass(v: Cell, highlight: boolean): string {
  if (v === "y") return highlight ? "text-[var(--green)] font-bold" : "text-[var(--green)]";
  if (v === "n") return "text-[var(--dim)] opacity-50";
  if (v === "p") return "text-[var(--accent)] opacity-80";
  return "text-[var(--dim)] font-mono text-[11px] whitespace-nowrap";
}
---

<section class="border-b border-[var(--border)] bg-[var(--bg)]">
  <div class="mx-auto max-w-6xl px-6 py-20 max-sm:px-4 max-sm:py-14">
    <div class="max-w-2xl">
      <div
        class="font-mono text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--accent)]"
      >
        How it compares
      </div>
      <h2
        class="mt-3 font-sans text-[clamp(1.7rem,3.4vw,2.4rem)] font-bold leading-tight tracking-[-0.02em] text-[var(--bright)]"
      >
        Built for the things other terminal-over-browser tools don't do.
      </h2>
      <p class="mt-3 text-[14.5px] text-[var(--dim)]">
        We respect the existing tools — most served their generation well.
        Here is where blit diverges, in plain terms.
      </p>
    </div>

    <div class="mt-10 overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--bg-elevated)]">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-[13px]">
          <thead>
            <tr class="border-b border-[var(--border)] bg-[var(--surface)]">
              <th
                class="sticky left-0 bg-[var(--surface)] px-4 py-3 text-left font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[var(--dim)]"
              >
                Feature
              </th>
              {
                cols.map(({ label, sub, highlight }) => (
                  <th
                    class:list={[
                      "px-3 py-3 text-center align-bottom font-mono text-[12px] font-bold tracking-tight",
                      highlight
                        ? "bg-[var(--accent-soft)] text-[var(--bright)]"
                        : "text-[var(--dim)]",
                    ]}
                  >
                    <div>{label}</div>
                    {sub && (
                      <div class="font-normal text-[10px] uppercase tracking-wider opacity-70">
                        {sub}
                      </div>
                    )}
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row, i) => (
                <tr
                  class:list={[
                    "border-b border-[var(--border)] last:border-0",
                    i % 2 === 1 && "bg-[var(--surface)]/30",
                  ]}
                >
                  <td class="sticky left-0 bg-[var(--bg-elevated)] px-4 py-3 font-medium text-[var(--fg)]">
                    {row.feature}
                  </td>
                  {cols.map(({ key, highlight }) => {
                    const v = row[key] as Cell;
                    return (
                      <td
                        class:list={[
                          "px-3 py-3 text-center align-middle text-[14px]",
                          cellClass(v, !!highlight),
                          highlight && "bg-[var(--accent-soft)]",
                        ]}
                      >
                        {cellText(v)}
                      </td>
                    );
                  })}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <div
      class="mt-4 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 font-mono text-[11px] text-[var(--dim)]"
    >
      <span><span class="text-[var(--green)]">✓</span> first-class</span>
      <span><span class="text-[var(--accent)]">~</span> partial / addon</span>
      <span><span class="opacity-60">—</span> not supported</span>
    </div>
  </div>
</section>
