---
const productLinks = [
  { label: "Install", href: "#install" },
  { label: "How it works", href: "#how" },
  { label: "Comparison", href: "#compare" },
  { label: "Embed", href: "#embed" },
];

const docsLinks = [
  { label: "README", href: "https://github.com/indent-com/blit/blob/main/README.md" },
  { label: "Architecture", href: "https://github.com/indent-com/blit/blob/main/ARCHITECTURE.md" },
  { label: "Embedding", href: "https://github.com/indent-com/blit/blob/main/EMBEDDING.md" },
  { label: "Services", href: "https://github.com/indent-com/blit/blob/main/SERVICES.md" },
  { label: "Agent skill", href: "https://install.blit.sh/SKILL.md" },
];

const repoLinks = [
  { label: "Repository", href: "https://github.com/indent-com/blit" },
  { label: "Releases", href: "https://github.com/indent-com/blit/releases" },
  { label: "Issues", href: "https://github.com/indent-com/blit/issues" },
  { label: "Contributing", href: "https://github.com/indent-com/blit/blob/main/CONTRIBUTING.md" },
  { label: "MIT License", href: "https://github.com/indent-com/blit/blob/main/LICENSE" },
];
---

<footer class="bg-[var(--bg-soft)]/40">
  <div class="mx-auto max-w-6xl px-6 py-12 max-sm:px-4 max-sm:py-10">
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
      <div class="col-span-2 sm:col-span-1">
        <div class="flex items-center gap-2.5">
          <span class="grid h-7 w-7 place-items-center rounded-md bg-[var(--bright)]">
            <svg viewBox="0 0 100 100" width="18" height="18" aria-hidden="true">
              <text
                x="12"
                y="76"
                font-family="monospace"
                font-size="72"
                font-weight="bold"
                fill="var(--bg)">b</text
              >
              <rect
                x="60"
                y="24"
                width="8"
                height="52"
                rx="2"
                fill="var(--accent)"
                opacity="0.85"></rect>
            </svg>
          </span>
          <span class="font-mono font-bold text-[15px] tracking-tight">blit</span>
        </div>
        <p class="mt-3 max-w-xs text-[12.5px] leading-relaxed text-[var(--dim)]">
          Terminals for the web and machines. Single binary, no required
          dependencies.
        </p>
      </div>

      <div>
        <div
          class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[var(--dim)]"
        >
          Product
        </div>
        <ul class="mt-3 flex flex-col gap-2 text-[12.5px]">
          {
            productLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-[var(--fg)] no-underline transition-colors hover:text-[var(--accent)]"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <div
          class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[var(--dim)]"
        >
          Docs
        </div>
        <ul class="mt-3 flex flex-col gap-2 text-[12.5px]">
          {
            docsLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--fg)] no-underline transition-colors hover:text-[var(--accent)]"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <div
          class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[var(--dim)]"
        >
          Repo
        </div>
        <ul class="mt-3 flex flex-col gap-2 text-[12.5px]">
          {
            repoLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[var(--fg)] no-underline transition-colors hover:text-[var(--accent)]"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-[var(--border)] pt-5 font-mono text-[11px] text-[var(--dim)]"
    >
      <span>
        Built by
        <a
          href="https://indent.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--accent)] no-underline hover:underline">Indent</a
        >. MIT-licensed.
      </span>
      <span>
        Wide chars · emoji · Unicode · WebGPU · WebGL · canvas2d
      </span>
    </div>
  </div>
</footer>
