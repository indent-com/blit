---
const blocks = [
  {
    eyebrow: "Share & connect",
    title: "Hand a teammate a URL.",
    body:
      "WebRTC punches through NATs — no SSH keys, no port forwarding. For permanent access, name your SSH remotes once. blit auto-installs itself on the remote on the first connection.",
    code: `<span class="text-[var(--green)] select-none">$</span> blit share
Terminals at <span class="text-[var(--accent)] underline">https://blit.sh/s#rf6e…</span>
Read-only:  <span class="text-[var(--accent)] underline">https://blit.sh/s#EMPs…</span>

<span class="text-[var(--green)] select-none">$</span> blit remote add prod ssh:alice@prod.co
<span class="text-[var(--green)] select-none">$</span> blit --on prod terminal list
<span class="text-[var(--dim)]">2  build (running)</span>
<span class="text-[var(--dim)]">3  shell (idle)</span>`,
  },
  {
    eyebrow: "Terminals as an API",
    title: "Drive sessions from a script — or an LLM.",
    body:
      "Non-interactive subcommands work over the parsed terminal grid: start a process, send keystrokes, wait for a regex, read the screen as text. We ship a computer-agent skill any model can pick up.",
    code: `<span class="text-[var(--green)] select-none">$</span> blit terminal start -t build make -j8
<span class="text-[var(--hl-num)]">1</span>
<span class="text-[var(--green)] select-none">$</span> blit terminal wait 1 --pattern <span class="text-[var(--hl-str)]">'BUILD OK'</span>
<span class="text-[var(--green)] select-none">$</span> blit terminal show 1 | tail -2
<span class="text-[var(--dim)]">[100%] Built target app</span>
<span class="text-[var(--green)]">BUILD OK</span>

<span class="text-[var(--green)] select-none">$</span> blit terminal send 1 <span class="text-[var(--hl-str)]">"q"</span>`,
  },
  {
    eyebrow: "GUI apps & audio",
    title: "Stream graphical apps without a display.",
    body:
      "Every blit terminal includes an experimental headless Wayland compositor. Launch foot, mpv, or a browser; capture the surface, click into it, type. Encoded as H.264 / AV1 with NVENC, VA-API, or software fallback.",
    code: `<span class="text-[var(--green)] select-none">$</span> blit terminal start foot
<span class="text-[var(--hl-num)]">1</span>
<span class="text-[var(--green)] select-none">$</span> blit surface list
<span class="text-[var(--dim)]">1  foot — 1024x768 — av1-vaapi</span>
<span class="text-[var(--green)] select-none">$</span> blit surface capture 1 screenshot.png
<span class="text-[var(--green)] select-none">$</span> blit surface click 1 100 50
<span class="text-[var(--green)] select-none">$</span> blit surface type 1 <span class="text-[var(--hl-str)]">"hello{Return}"</span>`,
    badge: "Experimental",
  },
  {
    eyebrow: "Clipboard",
    title: "Move bytes through the compositor clipboard.",
    body:
      "Read and write the compositor clipboard with any MIME type — text, images, custom formats. Same API for local terminals, share links, and SSH remotes.",
    code: `<span class="text-[var(--green)] select-none">$</span> blit clipboard list
<span class="text-[var(--dim)]">text/plain;charset=utf-8</span>
<span class="text-[var(--dim)]">text/plain</span>

<span class="text-[var(--green)] select-none">$</span> blit clipboard get
hello world

<span class="text-[var(--green)] select-none">$</span> blit clipboard set <span class="text-[var(--hl-str)]">"new value"</span>`,
  },
];
---

<section class="border-b border-[var(--border)] bg-[var(--bg-soft)]/50">
  <div class="mx-auto max-w-6xl px-6 py-20 max-sm:px-4 max-sm:py-14">
    <div class="max-w-2xl">
      <div
        class="font-mono text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--accent)]"
      >
        See it
      </div>
      <h2
        class="mt-3 font-sans text-[clamp(1.7rem,3.4vw,2.4rem)] font-bold leading-tight tracking-[-0.02em] text-[var(--bright)]"
      >
        Four commands, four superpowers.
      </h2>
    </div>

    <div class="mt-12 flex flex-col gap-12">
      {
        blocks.map(({ eyebrow, title, body, code, badge }, i) => (
          <div
            class:list={[
              "grid grid-cols-1 gap-6 lg:grid-cols-2 lg:items-center lg:gap-10",
              i % 2 === 1 && "lg:[&>*:first-child]:order-2",
            ]}
          >
            <div>
              <div class="flex items-center gap-2 font-mono text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--accent)]">
                <span>{eyebrow}</span>
                {badge && (
                  <span class="rounded-full border border-[var(--accent)]/40 bg-[var(--accent-soft)] px-2 py-0.5 text-[9px] tracking-wider">
                    {badge}
                  </span>
                )}
              </div>
              <h3 class="mt-2 font-sans text-[clamp(1.4rem,2.6vw,1.8rem)] font-bold leading-tight tracking-[-0.02em] text-[var(--bright)]">
                {title}
              </h3>
              <p class="mt-3 max-w-md text-[14.5px] leading-relaxed text-[var(--dim)]">
                {body}
              </p>
            </div>
            <div class="relative" data-theme="dark">
              <div
                aria-hidden="true"
                class="pointer-events-none absolute -inset-4 -z-10 rounded-2xl opacity-50 blur-2xl"
                style="background: radial-gradient(20rem 12rem at 50% 50%, var(--accent-glow), transparent 70%);"
              />
              <div class="overflow-hidden rounded-xl border border-[#21262d] bg-[#0a0d12] shadow-lg">
                <div class="flex items-center gap-2 border-b border-[#21262d] bg-[#11161d] px-3 py-1.5">
                  <span class="h-2 w-2 rounded-full bg-[#ff5f57]" />
                  <span class="h-2 w-2 rounded-full bg-[#febc2e]" />
                  <span class="h-2 w-2 rounded-full bg-[#28c840]" />
                  <span class="ml-2 font-mono text-[10px] uppercase tracking-wider text-[var(--dim)]">
                    {eyebrow}
                  </span>
                </div>
                <pre class="m-0 overflow-x-auto bg-[var(--code-bg)] px-4 py-3.5"><code class="font-mono text-[12.5px] leading-relaxed text-[var(--code-fg)]" set:html={code} /></pre>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
