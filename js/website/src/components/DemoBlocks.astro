---
const remotes = `<span class="text-[var(--green)] select-none">$</span> blit share
Terminals at https://blit.sh/s#rf6e…
Read-only: https://blit.sh/s#EMPs…

<span class="text-[var(--green)] select-none">$</span> blit remote add dev ssh:dev
<span class="text-[var(--green)] select-none">$</span> blit --on dev terminal list`;

const agentApi = `<span class="text-[var(--green)] select-none">$</span> blit terminal start -t build make -j8
1
<span class="text-[var(--green)] select-none">$</span> blit terminal wait 1 --pattern 'BUILD OK'
<span class="text-[var(--green)] select-none">$</span> blit terminal show 1
[100%] Built target app
BUILD OK`;

const compositor = `<span class="text-[var(--green)] select-none">$</span> blit terminal start foot
1
<span class="text-[var(--green)] select-none">$</span> blit surface list
<span class="text-[var(--green)] select-none">$</span> blit surface capture 1 screenshot.png
<span class="text-[var(--green)] select-none">$</span> blit surface click 1 100 50`;

const clipboard = `<span class="text-[var(--green)] select-none">$</span> blit clipboard list
text/plain;charset=utf-8
text/plain
<span class="text-[var(--green)] select-none">$</span> blit clipboard get
hello world
<span class="text-[var(--green)] select-none">$</span> blit clipboard set "new value"`;

const blocks = [
  {
    title: "Share & connect",
    desc: "WebRTC punches through NATs — no SSH keys, no port forwarding. Named remotes for SSH hosts, auto-installed on first connection.",
    code: remotes,
  },
  {
    title: "Terminals as an API",
    desc: "Non-interactive subcommands for scripts and LLMs. Parsed terminal grid, LZ4-compressed binary diffs — not pixels.",
    code: agentApi,
  },
  {
    title: "GUI apps & audio",
    desc: "Headless Wayland compositor streams GUI apps as H.264 / AV1 video. Audio forwarded via PipeWire and streamed as Opus. Linux only.",
    code: compositor,
  },
  {
    title: "Clipboard",
    desc: "Read and write the compositor clipboard. List MIME types, get/set with any MIME — text, images, or custom formats.",
    code: clipboard,
  },
];
---

<section class="pb-10">
  <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
    {blocks.map(({ title, desc, code }) => (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-lg overflow-hidden flex flex-col">
        <div class="px-4 pt-3 pb-2">
          <div class="text-[11px] font-bold uppercase tracking-wider text-[var(--dim)]">
            {title}
          </div>
          <p class="text-[12px] leading-relaxed text-[var(--dim)] mt-1 mb-0">{desc}</p>
        </div>
        <pre
          class="m-0 px-4 py-2.5 overflow-x-auto flex-1"><code class="font-mono text-[13px] leading-relaxed text-[var(--code-fg)]" set:html={code} /></pre>
      </div>
    ))}
  </div>
</section>
