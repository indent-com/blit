---
import CopyButton from "./CopyButton.tsx";

const skillUrl = "https://install.blit.sh/SKILL.md";
---

<section class="py-10 border-t border-[var(--border)]">
  <h2 class="text-base font-bold tracking-tight mb-1 text-[var(--bright)]">
    Agent skill
  </h2>
  <p class="text-[13px] leading-relaxed text-[var(--dim)] mb-4 max-w-[42rem]">
    We publish a <strong class="text-[var(--fg)]">computer agent skill</strong> — a
    ready-made instruction set that teaches any LLM to start sessions, send
    keystrokes, wait for patterns, capture GUI surfaces, and more.
    Drop it straight into your agent's context.
  </p>
  <div class="bg-[var(--surface)] border border-[var(--border)] rounded-lg px-4 py-3">
    <div class="text-[11px] font-bold uppercase tracking-wider text-[var(--dim)] mb-2">
      Skill URL
    </div>
    <div class="flex items-center gap-2">
      <a
        href={skillUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 min-w-0 text-[13px] font-mono text-[var(--accent)] no-underline hover:underline truncate"
      >
        {skillUrl}
      </a>
      <CopyButton text={skillUrl} client:load />
    </div>
  </div>
  <p class="mt-3 text-[12px] text-[var(--dim)] opacity-70">
    Covers PTY lifecycle, keystroke sending, output reading, Wayland surface capture, click/type, and session management.
  </p>
</section>
