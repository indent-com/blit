#!/usr/bin/env bash
# Runs bin/dev (process-compose), waits for every service to come up healthy,
# smoke-tests with the blit CLI, then tears everything down.
set -euo pipefail
cd "$(dirname "$0")/.."

# Use a dedicated instance so dev-check never collides with a developer's
# running ./bin/dev (instance 0).  Override DEV_INSTANCE for parallel CI.
export DEV_INSTANCE="${DEV_INSTANCE:-99}"

# bin/dev computes all concrete vars from the instance; we just need to know
# the socket path for the smoke test and the PC socket for health polling.
N="$DEV_INSTANCE"
BLIT_DEV_SOCK="${BLIT_DEV_SOCK:-/tmp/blit-dev-${N}.sock}"
PC_SOCK="/tmp/blit-dev-pc-${N}.sock"
TIMEOUT="${DEV_CHECK_TIMEOUT:-600}"

cleanup() {
    echo "=== Tearing down ==="
    process-compose -U -u "$PC_SOCK" down 2>/dev/null || true
    rm -f "$PC_SOCK" "$BLIT_DEV_SOCK"
}
trap cleanup EXIT INT TERM

rm -f "$PC_SOCK" "$BLIT_DEV_SOCK"

# Ensure js/ui/dist/index.html{,.br} exist so `cargo build -p blit-cli` can
# compile blit-gateway (which embeds them via include_bytes!).  On a fresh
# checkout the dist hasn't been built yet — create minimal stubs.
# The smoke test only exercises the CLI, not the web UI, so content doesn't
# matter; it just needs to be a valid file the compiler can read.
if [ ! -f js/ui/dist/index.html.br ]; then
    echo "=== Creating stub js/ui/dist/index.html.br ==="
    mkdir -p js/ui/dist
    echo '<html><body>stub</body></html>' > js/ui/dist/index.html
    # Use Python brotli compression if available, otherwise a raw copy
    # (the gateway will serve bogus content, but the CLI smoke test never
    # fetches the web UI).
    python3 -c "
import brotli, pathlib, sys
html = pathlib.Path('js/ui/dist/index.html').read_bytes()
pathlib.Path('js/ui/dist/index.html.br').write_bytes(brotli.compress(html))
" 2>/dev/null || cp js/ui/dist/index.html js/ui/dist/index.html.br
fi

echo "=== Installing blit CLI ==="
curl -sf https://install.blit.sh | sh
BLIT="blit"

echo "=== Starting bin/dev ==="
./bin/dev -t=false &
DEV_PID=$!

echo "=== Waiting for all services to become healthy (timeout ${TIMEOUT}s) ==="
start_time=$(date +%s)
deadline=$((start_time + TIMEOUT))
while true; do
    now=$(date +%s)
    elapsed=$((now - start_time))

    if ! kill -0 "$DEV_PID" 2>/dev/null; then
        echo "FATAL: bin/dev exited unexpectedly"
        wait "$DEV_PID" || true
        exit 1
    fi

    if [ "$now" -ge "$deadline" ]; then
        echo "FATAL: timed out waiting for services after ${elapsed}s"
        process-compose -U -u "$PC_SOCK" list 2>/dev/null || true
        exit 1
    fi

    if status=$(process-compose -U -u "$PC_SOCK" list -o json 2>/dev/null); then
        total=$(echo "$status" | jq 'length')
        ready=$(echo "$status" | jq '[.[] | select((.status == "Running" and ((.has_ready_probe | not) or .is_ready == "Ready")) or .status == "Completed")] | length')
        echo "  services: $ready/$total ready (${elapsed}s)"
        if [ "$total" -gt 0 ] && [ "$ready" -eq "$total" ]; then
            break
        fi
    fi

    sleep 5
done

echo "=== All services ready ==="
process-compose -U -u "$PC_SOCK" list

echo ""
echo "=== Smoke test: blit CLI ==="
export BLIT_SOCK="$BLIT_DEV_SOCK"

echo "  blit terminal start echo hello"
SESSION_ID=$("$BLIT" terminal start echo hello)
echo "  terminal: $SESSION_ID"

echo "  blit terminal wait"
"$BLIT" terminal wait "$SESSION_ID" --timeout 30

echo "  blit terminal history"
OUTPUT=$("$BLIT" terminal history "$SESSION_ID" --from-start 0 --limit 50)
if echo "$OUTPUT" | grep -q "hello"; then
    echo "  output contains 'hello' ✓"
else
    echo "FATAL: expected 'hello' in output, got:"
    echo "$OUTPUT"
    exit 1
fi

echo "  blit terminal list"
"$BLIT" terminal list

echo "  blit terminal close"
"$BLIT" terminal close "$SESSION_ID"

echo ""
echo "=== dev-check passed ==="
