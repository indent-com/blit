#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

echo "Building blit npm package via Nix..."
out=$(nix build .#blit-npm --no-link --print-out-paths)

# Stage into a temp directory so we can overlay package.json
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT
cp -a "$out"/* "$tmp"/
chmod -R u+w "$tmp"

# wasm-pack generates a package.json; replace it with ours
cat > "$tmp/package.json" <<'EOF'
{
  "name": "blit-wasm",
  "version": "0.1.0",
  "description": "Low-latency terminal streaming — JS+WASM client for WebRTC datachannel",
  "type": "module",
  "main": "blit.js",
  "types": "blit.d.ts",
  "files": [
    "blit_bg.wasm",
    "blit_bg.js",
    "blit_bg.wasm.d.ts",
    "blit.js",
    "blit.d.ts"
  ],
  "keywords": ["terminal", "tty", "wasm", "webrtc", "streaming"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indent-com/blit"
  }
}
EOF

echo "Package contents:"
ls -lh "$tmp"

echo ""
echo "Publishing from $tmp ..."
nix shell nixpkgs#nodejs -c npm publish "$tmp" "$@"
